{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "啖놵럇鬧뷘묶",
  "version": "0.2.0",
  "identifier": "com.dreamnarrativeengine.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://127.0.0.1:8850",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "啖놵럇鬧뷘묶",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; media-src 'self' asset: http://asset.localhost data: blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/embedding-models/": "embedding-models/"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese"
        ]
      },
      "wix": {
        "language": "zh-CN"
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
