type DiscoverModelsParams = {
  provider: string;
  base_url: string;
  api_key: string;
};

export async function discoverModels(
  providerOrParams: string | DiscoverModelsParams,
  baseUrl?: string,
  apiKey?: string,
) {
  const params =
    typeof providerOrParams === "string"
      ? {
          provider: providerOrParams,
          base_url: baseUrl ?? "",
          api_key: apiKey ?? "",
        }
      : providerOrParams;
  if (isTauri) {
    return getTauri().discoverModels(
      params.provider,
      params.base_url,
      params.api_key,
    );
  }
  return getHttp().discoverModels(params);
}

