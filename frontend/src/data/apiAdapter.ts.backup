export function onSessionSnapshot(sessionId: string, callback: (snapshot: import("./tauriApi").SessionSnapshot) => void): () => void {
  if (isTauri) {
    return getTauri().onSessionSnapshot(sessionId, callback);
  }
  // HTTP 模式下使用 WebSocket 接收实时更新
  const wsUrl = getHttp().toSessionWebSocketUrl(sessionId);
  const ws = new WebSocket(wsUrl);
  ws.onmessage = (event) => {
    try {
      const data = JSON.parse(event.data);
      if (data.type === "snapshot" && data.payload) {
        callback(data.payload);
      }
    } catch {
      // 忽略单条消息解析失败，继续保持连接
    }
  };
  return () => ws.close();
}

export function toSessionWebSocketUrl(sessionId: string): string {
  if (isTauri) {
    throw new Error("WebSocket URL is unavailable in Tauri mode; use Tauri events instead.");
  }
  return getHttp().toSessionWebSocketUrl(sessionId);
}

export function assetUrl(path: string | null | undefined): string {
  return isTauri ? getTauri().assetUrl(path) : getHttp().assetUrl(path ?? "");
}
